# =============================================================================
# iesolver — environment variables
# =============================================================================
# Bu dosyayı `.env` olarak kopyala, sonra GOOGLE_API_KEY'i doldur.
# .env'in repo'ya commit edilmemesi için .gitignore'a ekli olduğunu varsay.

# REQUIRED — Faz 2'den itibaren (gerçek LLM çağrıları)
# https://aistudio.google.com/apikey adresinden ücretsiz alabilirsin.
GOOGLE_API_KEY=

# OPTIONAL — modeller (varsayılanlar config.py'de tanımlı)
# FAST_MODEL=gemini/gemini-2.5-flash-lite
# REASONING_MODEL=gemini/gemini-2.5-pro

# OPTIONAL — güvenlik & limitler
# MAX_RETRIES=3
# TIMEOUT_SECONDS=60
# BUDGET_LIMIT_USD=5.0

# OPTIONAL — persistence paths (göreceli yollar proje köküne göre)
# CHECKPOINT_DB_PATH=.iesolver/checkpoints.sqlite
# ARTIFACTS_DIR=.iesolver/artifacts
# OUTPUT_DIR=.iesolver/outputs
# SANDBOX_WORKDIR=.iesolver/sandbox

# OPTIONAL — UI
# DEFAULT_OUTPUT_FORMAT=html
